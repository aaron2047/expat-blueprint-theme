{% schema %}
{
  "name": "E-E-A-T / FAQ",
  "class": "section-eeat",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "E-E-A-T Matrix"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "2026 Data Verification & Compliance Standards"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every figure inside the blueprint is sourced, dated, and re-audited each release cycle."
    }
  ]
}
{% endschema %}

<style>
  .section-eeat {
    background: #fcfdfd;
    padding: 6rem 2rem;
    border-bottom: 1px solid #e6e8ea;
  }

  .eeat-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 3.5rem;
    align-items: start;
  }

  .eeat-eyebrow {
    font-size: 8.5px;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(26,95,122,0.7);
    margin: 0 0 1rem;
  }

  .eeat-headline {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(24px, 2.5vw, 34px);
    font-weight: 700;
    line-height: 1.2;
    color: #1a5f7a;
    margin: 0 0 1.25rem;
  }

  .eeat-rule {
    width: 48px;
    height: 2px;
    background: #8bc34a;
    margin-bottom: 1.5rem;
  }

  .eeat-subtext {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(26,95,122,0.75);
    margin: 0;
  }

  /* Accordion */
  .eeat-accordion {
    width: 100%;
  }

  .eeat-item {
    border-bottom: 1px solid rgba(26,95,122,0.15);
  }

  .eeat-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 17px;
    font-weight: 700;
    line-height: 1.3;
    color: #1a5f7a;
  }

  .eeat-trigger:hover { color: #13495e; }

  .eeat-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    position: relative;
    transition: transform 0.3s ease;
  }

  .eeat-icon::before,
  .eeat-icon::after {
    content: '';
    position: absolute;
    background: #8bc34a;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .eeat-icon::before {
    width: 12px;
    height: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .eeat-icon::after {
    width: 2px;
    height: 12px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .eeat-item.is-open .eeat-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  .eeat-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }

  .eeat-body-inner {
    padding: 0 0 1.5rem;
    font-size: 14px;
    line-height: 1.75;
    color: rgba(26,95,122,0.8);
  }

  @media (max-width: 760px) {
    .eeat-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<section class="section-eeat" id="verification">
  <div class="eeat-inner">

    <!-- LEFT: heading -->
    <div>
      <p class="eeat-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="eeat-headline">{{ section.settings.headline | escape }}</h2>
      <div class="eeat-rule"></div>
      <p class="eeat-subtext">{{ section.settings.subtext }}</p>
    </div>

    <!-- RIGHT: accordion -->
    <div class="eeat-accordion" id="eeat-accordion-{{ section.id }}">

      <div class="eeat-item">
        <button class="eeat-trigger" aria-expanded="false">
          How is the data verified?
          <span class="eeat-icon" aria-hidden="true"></span>
        </button>
        <div class="eeat-body" role="region">
          <div class="eeat-body-inner">
            Every visa threshold, country snapshot, and regulatory baseline is actively audited against current 2026 framework releases, including active IRCC Express Entry draws, NMC Test of Competence timelines, and current ocean freight indices.
          </div>
        </div>
      </div>

      <div class="eeat-item">
        <button class="eeat-trigger" aria-expanded="false">
          Does this replace legal counsel?
          <span class="eeat-icon" aria-hidden="true"></span>
        </button>
        <div class="eeat-body" role="region">
          <div class="eeat-body-inner">
            This guide is for general informational and educational purposes only and is not legal, immigration, tax, or financial advice. All listings are structured to act as your operational checklist before you engage certified cross-border practitioners.
          </div>
        </div>
      </div>

      <div class="eeat-item">
        <button class="eeat-trigger" aria-expanded="false">
          How is the digital asset delivered?
          <span class="eeat-icon" aria-hidden="true"></span>
        </button>
        <div class="eeat-body" role="region">
          <div class="eeat-body-inner">
            Fulfillment is handled completely automatically. The exact second your payment clears at checkout, a secure high-definition vector PDF asset link is routed directly to your checkout email token.
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var accordion = document.getElementById('eeat-accordion-{{ section.id }}');
  if (!accordion) return;

  accordion.addEventListener('click', function (e) {
    var trigger = e.target.closest('.eeat-trigger');
    if (!trigger) return;

    var item   = trigger.closest('.eeat-item');
    var body   = item.querySelector('.eeat-body');
    var isOpen = item.classList.contains('is-open');

    // Close all
    accordion.querySelectorAll('.eeat-item.is-open').forEach(function (openItem) {
      openItem.classList.remove('is-open');
      openItem.querySelector('.eeat-body').style.maxHeight = '0';
      openItem.querySelector('.eeat-trigger').setAttribute('aria-expanded', 'false');
    });

    // Open clicked (if it was closed)
    if (!isOpen) {
      item.classList.add('is-open');
      body.style.maxHeight = body.scrollHeight + 'px';
      trigger.setAttribute('aria-expanded', 'true');
    }
  });
})();
</script>
