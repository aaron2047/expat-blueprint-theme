{% schema %}
{
  "name": "Pricing Tiers",
  "class": "section-pricing",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Monetization Tiers"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Select Your Operational Tier"
    }
  ]
}
{% endschema %}

<style>
  .section-pricing {
    background: #fff;
    padding: 6rem 2rem;
    border-top: 1px solid #e6e8ea;
    border-bottom: 1px solid #e6e8ea;
  }

  .pricing-header {
    max-width: 720px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }

  .pricing-eyebrow {
    font-size: 8.5px;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(26,95,122,0.7);
    margin: 0 0 1.25rem;
  }

  .pricing-headline {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    color: #1a5f7a;
    margin: 0 0 1.25rem;
  }

  .pricing-rule {
    width: 56px;
    height: 2px;
    background: #8bc34a;
    margin: 0 auto;
  }

  .pricing-grid {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e6e8ea;
    padding: 2rem;
    transition: border-color 0.2s;
  }

  .pricing-card:hover {
    border-color: rgba(26,95,122,0.4);
  }

  .pricing-card--recommended {
    border-color: #1a5f7a;
    box-shadow: 0 24px 60px -30px rgba(26,95,122,0.4);
    margin-top: -1rem;
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #8bc34a;
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 4px 12px;
    white-space: nowrap;
  }

  .pricing-name {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #1a5f7a;
    margin: 0 0 0.5rem;
  }

  .pricing-name-rule {
    width: 40px;
    height: 2px;
    background: #8bc34a;
    margin-bottom: 1.5rem;
  }

  .pricing-price-row {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 1.75rem;
  }

  .pricing-price {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 40px;
    font-weight: 700;
    line-height: 1;
    color: #1a5f7a;
  }

  .pricing-currency {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(26,95,122,0.6);
  }

  .pricing-features {
    list-style: none;
    margin: 0 0 auto;
    padding: 0;
    border-top: 1px solid #e6e8ea;
    padding-top: 1.5rem;
    flex: 1;
  }

  .pricing-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.55;
    color: rgba(26,95,122,0.85);
    margin-bottom: 0.75rem;
  }

  .pricing-check {
    flex-shrink: 0;
    margin-top: 3px;
    width: 14px;
    height: 14px;
    color: #8bc34a;
  }

  .pricing-btn {
    display: block;
    margin-top: 2rem;
    padding: 14px 24px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    border: 1px solid #1a5f7a;
    background: #fff;
    color: #1a5f7a;
  }

  .pricing-btn:hover {
    background: #1a5f7a;
    color: #fff;
  }

  .pricing-btn--recommended {
    background: #8bc34a;
    border-color: #8bc34a;
    color: #fff;
  }

  .pricing-btn--recommended:hover {
    background: #7cb53d;
    border-color: #7cb53d;
    color: #fff;
  }

  @media (max-width: 860px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
    }
    .pricing-card--recommended {
      margin-top: 0;
    }
  }
</style>

<section class="section-pricing" id="pricing">
  <div class="pricing-header">
    <p class="pricing-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="pricing-headline">{{ section.settings.headline | escape }}</h2>
    <div class="pricing-rule"></div>
  </div>

  <div class="pricing-grid">

    <!-- TIER 1: Entry Manual — $27 — ACTIVE -->
