{% schema %}
{
  "name": "Pricing Tiers Section",
  "class": "section-pricing",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Select Your Operational Tier"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Entry Manual Product"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Blueprint Bundle Product (Featured)"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Concierge Product"
    }
  ]
}
{% endschema %}

<style>
  .section-pricing {
    padding: 4rem 2rem;
    background-color: #f9f7f3;
  }

  .pricing-title {
    font-family: Georgia, serif;
    font-size: 28px;
    text-align: center;
    margin-bottom: 3rem;
    color: #1a1f3a;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .pricing-tier {
    background-color: #ffffff;
    border: 0.5px solid #e5dcd0;
    padding: 2rem;
    position: relative;
    transition: transform 0.2s ease;
  }

  .pricing-tier:hover {
    transform: translateY(-4px);
  }

  .pricing-tier.featured {
    border: 2px solid #d4af37;
  }

  .pricing-tier.featured::before {
    content: 'Recommended';
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: #d4af37;
    color: #1a1f3a;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .tier-title {
    font-family: Georgia, serif;
    font-size: 16px;
    color: #1a1f3a;
    margin-bottom: 0.5rem;
  }

  .tier-price {
    font-family: Georgia, serif;
    font-size: 32px;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .tier-price-currency {
    font-size: 14px;
    color: #666666;
  }

  .tier-features {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }

  .tier-features li {
    padding: 0.5rem 0;
    color: #666666;
    font-size: 13px;
  }

  .tier-features li::before {
    content: '✓ ';
    color: #d4af37;
    margin-right: 8px;
    font-weight: bold;
  }

  .tier-cta {
    width: 100%;
    background-color: #1a1f3a;
    color: #d4af37;
    border: 1px solid #1a1f3a;
    padding: 10px;
    cursor: pointer;
    font-size: 13px;
    margin-top: 1rem;
    transition: all 0.2s ease;
  }

  .tier-cta:hover {
    opacity: 0.9;
  }

  .pricing-tier.featured .tier-cta {
    background-color: #d4af37;
    color: #1a1f3a;
  }

  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .section-pricing {
      padding: 2rem 1.5rem;
    }

    .pricing-title {
      font-size: 22px;
    }

    .tier-cta {
      width: 100%;
    }
  }
</style>

<section class="section-pricing">
  <div class="container">
    <h2 class="pricing-title">{{ section.settings.section_title }}</h2>
    <div class="pricing-grid">
      {% if section.settings.product_1 %}
        <div class="pricing-tier">
          <h3 class="tier-title">{{ section.settings.product_1.title }}</h3>
          <div class="tier-price">
            ${{ section.settings.product_1.price | money_without_currency | remove: '.00' }}
            <span class="tier-price-currency">USD</span>
          </div>
          <ul class="tier-features">
            <li>Complete 249-page 2026 Master Guide</li>
            <li>Full 24-country operational directory</li>
            <li>License reciprocity mappings</li>
            <li>Complete customs clearing corridors</li>
          </ul>
          <a href="{{ section.settings.product_1.url }}" class="tier-cta">Purchase Manual</a>
        </div>
      {% endif %}

      {% if section.settings.product_2 %}
        <div class="pricing-tier featured">
          <h3 class="tier-title">{{ section.settings.product_2.title }}</h3>
          <div class="tier-price">
            ${{ section.settings.product_2.price | money_without_currency | remove: '.00' }}
            <span class="tier-price-currency">USD</span>
          </div>
          <ul class="tier-features">
            <li>Everything in the Entry Manual</li>
            <li>Interactive personal visa points calculator sheets</li>
            <li>Structural credential tracking templates</li>
            <li>Printable pre-flight 30/60/90 checklist workbook</li>
          </ul>
          <a href="{{ section.settings.product_2.url }}" class="tier-cta">Get Bundle</a>
        </div>
      {% endif %}

      {% if section.settings.product_3 %}
        <div class="pricing-tier">
          <h3 class="tier-title">{{ section.settings.product_3.title }}</h3>
          <div class="tier-price">
            ${{ section.settings.product_3.price | money_without_currency | remove: '.00' }}
            <span class="tier-price-currency">USD</span>
          </div>
          <ul class="tier-features">
            <li>The complete digital bundle</li>
            <li>Private access to our premium global mobility network forum</li>
            <li>Prioritized data update alerts</li>
            <li>Customized relocation milestone audit matrix</li>
          </ul>
          <a href="{{ section.settings.product_3.url }}" class="tier-cta">Get Concierge Access</a>
        </div>
      {% endif %}
    </div>
  </div>
</section>
