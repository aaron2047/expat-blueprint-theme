    <div class="pricing-card pricing-card--recommended">
      <span class="pricing-badge">Recommended</span>
      <h3 class="pricing-name">The Blueprint Bundle</h3>
      <div class="pricing-name-rule"></div>
      <div class="pricing-price-row">
        <span class="pricing-price">$97</span>
        <span class="pricing-currency">USD</span>
      </div>
      <ul class="pricing-features">
        <li>
          <svg class="pricing-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Everything in the Entry Manual
        </li>
        <li>
          <svg class="pricing-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Interactive personal visa points calculator sheets
        </li>
        <li>
          <svg class="pricing-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Structural credential tracking templates
        </li>
        <li>
          <svg class="pricing-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Printable pre-flight 30/60/90 checklist workbook
        </li>
      </ul>
      <a href="/cart/54412851609905:1" class="pricing-btn pricing-btn--recommended">Get Bundle</a>
    </div>

    <!-- TIER 3: Concierge — $297 -->
    <div class="pricing-card">
      <h3 class="pricing-name">The Concierge Stream</h3>
      <div class="pricing-name-rule"></div>
      <div class="pricing-price-row">
        <span class="pricing-price">$297</span>
        <span class="pricing-currency">USD</span>
      </div>
      <ul class="pricing-features">
        <li>
          <svg class="pricing-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          The complete digital bundle
        </li>
        <li>
          <svg class="pricing-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
